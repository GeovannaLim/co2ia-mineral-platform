{
  "name": "Report",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Report name"
    },
    "mineral": {
      "type": "string",
      "enum": [
        "gold",
        "copper",
        "iron",
        "diamond",
        "bauxite"
      ],
      "description": "Target mineral"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "processing",
        "completed",
        "failed"
      ],
      "default": "pending",
      "description": "Report generation status"
    },
    "start_date": {
      "type": "string",
      "format": "date"
    },
    "end_date": {
      "type": "string",
      "format": "date"
    },
    "roi_type": {
      "type": "string",
      "enum": [
        "rectangle",
        "polygon",
        "coordinates"
      ],
      "default": "rectangle"
    },
    "roi_data": {
      "type": "string",
      "description": "JSON string of ROI coordinates"
    },
    "logo_url": {
      "type": "string",
      "description": "Uploaded logo URL"
    },
    "pdf_url": {
      "type": "string",
      "description": "Generated PDF URL"
    },
    "mineral_score": {
      "type": "number",
      "description": "Overall mineral potential score"
    },
    "top_zones": {
      "type": "string",
      "description": "JSON string of top zones data"
    },
    "statistics": {
      "type": "string",
      "description": "JSON string of statistics"
    },
    "environmental_indicators": {
      "type": "string",
      "description": "JSON string of environmental indicators"
    },
    "summary": {
      "type": "string",
      "description": "Executive summary text"
    }
  },
  "required": [
    "title",
    "mineral"
  ]
}